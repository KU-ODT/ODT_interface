    POLLING --> CONTROL{제어 명령}
    CONTROL -->|Pause| PAUSE[일시정지]
    CONTROL -->|Resume| RESUME[재개]
    CONTROL -->|Reset| RESET[리셋]
    
    style LOGIN fill:#1e3a5f
    style CONFIG fill:#2d4a2d
    style MISSION_SIMPLE fill:#4a2d2d
    style VERTIPORT fill:#4a3d2d
    style VIS fill:#2d2d4a
```

